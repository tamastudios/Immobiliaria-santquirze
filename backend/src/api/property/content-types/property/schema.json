{
  "kind": "collectionType",
  "collectionName": "properties",
  "info": {
    "singularName": "property",
    "pluralName": "properties",
    "displayName": "Propiedad",
    "description": "Inmuebles en venta o alquiler"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title" },
    "operation": {
      "type": "enumeration",
      "enum": ["venta", "alquiler"],
      "default": "venta",
      "required": true
    },
    "propertyType": {
      "type": "enumeration",
      "enum": ["piso", "casa", "chalet", "duplex", "local", "terreno"],
      "default": "piso",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["disponible", "reservado", "vendido", "alquilado", "destacado", "exclusiva"],
      "default": "disponible"
    },
    "tag": {
      "type": "enumeration",
      "enum": ["nuevo", "rebajado", "exclusiva", "vendido", "reservado"]
    },
    "price": { "type": "integer", "required": true },
    "location": { "type": "string" },
    "city": { "type": "string", "default": "Sant Quirze del Vallès" },
    "bedrooms": { "type": "integer", "default": 0 },
    "bathrooms": { "type": "integer", "default": 0 },
    "area": { "type": "integer", "default": 0 },
    "reference": { "type": "string" },
    "description": { "type": "text" },
    "features": { "type": "json" },
    "equipment": { "type": "json" },
    "energyCertificate": { "type": "string", "default": "en trámite" },
    "lat": { "type": "float" },
    "lng": { "type": "float" },
    "featured": { "type": "boolean", "default": false },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
